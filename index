<!DOCTYPE html>
<html>
<head>
<title>PEBSP Dashboard</title>
<style>
body { font-family: Arial; background: linear-gradient(135deg, #667eea, #764ba2); padding: 40px; color: white; }
.card { background: white; color: #333; padding: 15px; margin: 10px 0; border-radius: 8px; border-left: 5px solid #667eea; }
.done { border-left-color: #10b981; opacity: 0.8; }
h1 { text-align: center; }
h2 { margin-top: 30px; }
</style>
</head>
<body>
<h1>PEBSP Dashboard</h1>

<h2>Pendentes</h2>
<div id="pending"></div>

<h2>Processados</h2>
<div id="done"></div>

<script>
fetch('https://script.google.com/macros/s/AKfycbw2ImX5WCErtSAGkah1ZFiDpV8UOZAFxw6E_Mh7DV7oo5dHZuxMwFhnwFpSbsVl3SA/exec')
.then(r => r.json())
.then(data => {
  document.getElementById('pending').innerHTML = data.pending.map(e => '<div class="card">' + e.name + ' - ' + (e.size/1024/1024).toFixed(2) + ' MB</div>').join('');
  document.getElementById('done').innerHTML = data.done.map(e => '<div class="card done">' + e.name + ' - ' + (e.size/1024/1024).toFixed(2) + ' MB</div>').join('');
});
</script>
</body>
</html>
